{
  "name": "@rrulenet/core",
  "version": "0.1.7",
  "description": "Shared recurrence engine for parsing, querying, timezone-aware expansion, set composition, and text rendering.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rrulenet/core.git"
  },
  "homepage": "https://github.com/rrulenet/core#readme",
  "bugs": {
    "url": "https://github.com/rrulenet/core/issues"
  },
  "keywords": [
    "rrule",
    "recurrence",
    "rfc5545",
    "ical",
    "temporal",
    "calendar"
  ],
  "files": [
    "assets",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./engine": {
      "types": "./dist/engine.d.mts",
      "default": "./dist/engine.mjs"
    },
    "./options": {
      "types": "./dist/options.d.mts",
      "default": "./dist/options.mjs"
    },
    "./rule": {
      "types": "./dist/rule.d.mts",
      "default": "./dist/rule.mjs"
    },
    "./text": {
      "types": "./dist/text.d.mts",
      "default": "./dist/text.mjs"
    },
    "./time": {
      "types": "./dist/time.d.mts",
      "default": "./dist/time.mjs"
    }
  },
  "types": "./dist/index.d.mts",
  "scripts": {
    "build": "npm exec --package=tsdown --package=typescript -- tsdown --config tsdown.config.ts",
    "test": "npm run build && node --test test/**/*.test.js",
    "coverage": "npm run build && node --experimental-test-coverage --test-concurrency=1 --test-coverage-include=dist/**/*.mjs --test test/**/*.test.js",
    "coverage:badge": "node scripts/write-coverage-badge.mjs coverage-output.txt badges/coverage.json",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "temporal-polyfill": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
