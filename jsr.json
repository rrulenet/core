{
  "$schema": "https://jsr.io/schema/config-file.v1.json",
  "name": "@rrulenet/core",
  "version": "0.1.1",
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine.ts",
    "./options": "./src/options.ts",
    "./rule": "./src/rule.ts",
    "./text": "./src/text.ts",
    "./time": "./src/time.ts"
  },
  "exclude": [
    ".github/",
    "dist/",
    "package-lock.json",
    "package.json",
    "tsdown.config.ts",
    "tsconfig.json",
    "test/",
    "scripts/",
    "badges/",
    "coverage-output.txt",
    "node_modules/"
  ]
}
